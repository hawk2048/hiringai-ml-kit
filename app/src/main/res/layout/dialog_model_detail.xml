<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 模型图标和名称 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- 模型图标（使用分类颜色） -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_circle">

            <TextView
                android:id="@+id/dialogIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="LLM"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model Name"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/dialogCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 状态卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 状态行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/statusIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_download"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Status" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not installed"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/sizeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 MB"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- 下载进度条 -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/downloadProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:trackThickness="8dp"
                app:trackCornerRadius="4dp"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/primary_light" />

            <!-- 进度信息 -->
            <LinearLayout
                android:id="@+id/progressInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/progressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 KB/s"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 详情信息 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Details"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/detailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="14sp"
        android:textColor="@color/text_tertiary"
        android:lineSpacingMultiplier="1.3"
        android:maxHeight="120dp"
        android:scrollbars="vertical" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp" />

    <!-- 操作按钮区域 -->
    <LinearLayout
        android:id="@+id/actionButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 主按钮行：下载 / 开始使用 -->
        <LinearLayout
            android:id="@+id/primaryButtonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 下载按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownload"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Download"
                android:textSize="14sp"
                app:icon="@drawable/ic_download"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- 后台下载按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackgroundDownload"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Background"
                android:textSize="14sp"
                app:icon="@drawable/ic_cloud"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>

        <!-- 下载中按钮行：暂停 / 停止 -->
        <LinearLayout
            android:id="@+id/downloadingButtonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <!-- 暂停按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPause"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Pause"
                android:textSize="14sp"
                app:icon="@drawable/ic_pause"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- 停止按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Stop"
                android:textSize="14sp"
                app:icon="@drawable/ic_stop"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/error"
                android:textColor="@color/error"
                app:iconTint="@color/error" />

        </LinearLayout>

        <!-- 已安装按钮行：开始使用 / 删除 -->
        <LinearLayout
            android:id="@+id/installedButtonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <!-- 开始使用按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartUsing"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Start Using"
                android:textSize="14sp"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button" />

            <!-- 删除按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemove"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Remove"
                android:textSize="14sp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/error"
                android:textColor="@color/error"
                app:iconTint="@color/error" />

        </LinearLayout>

        <!-- 查看来源按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewSource"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="View on HuggingFace"
            android:textSize="13sp"
            app:icon="@drawable/ic_open_link"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:cornerRadius="10dp"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>

</LinearLayout>
