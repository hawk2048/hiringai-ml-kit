<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- 顶部标题区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HiringAI"
                        android:textSize="@dimen/text_xxl"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ML Kit 基准测试工具"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/spacing_xxs" />
                </LinearLayout>

                <!-- Logo 标识 -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:background="@drawable/bg_logo_circle"
                    android:padding="@dimen/spacing_sm"
                    android:contentDescription="Logo" />
            </LinearLayout>

            <!-- 设备信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_md"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- 卡片头部 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_device"
                            android:tint="@color/primary"
                            android:contentDescription="设备" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备信息"
                            android:textSize="@dimen/text_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/deviceInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="6dp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 存储状态卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_md"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- 卡片头部 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_storage"
                            android:tint="@color/success"
                            android:contentDescription="存储" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="存储状态"
                            android:textSize="@dimen/text_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>

                    <!-- 存储使用进度条 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/storageProgressBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:indicatorColor="@color/primary"
                            app:trackColor="@color/surface_variant"
                            app:trackCornerRadius="@dimen/radius_sm"
                            app:trackThickness="8dp"
                            android:max="100" />

                        <TextView
                            android:id="@+id/storageProgressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_tertiary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/storageInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 进度指示器 -->
            <LinearLayout
                android:id="@+id/progressSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:indicatorColor="@color/primary"
                    app:trackColor="@color/surface_variant"
                    app:trackCornerRadius="@dimen/radius_sm"
                    app:trackThickness="6dp"
                    android:max="100" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:textAlignment="center" />
            </LinearLayout>

            <!-- 功能入口卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_md"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- 卡片头部 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_apps"
                            android:tint="@color/accent"
                            android:contentDescription="功能" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="功能"
                            android:textSize="@dimen/text_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_marginStart="@dimen/spacing_sm" />
                    </LinearLayout>

                    <!-- 功能按钮网格 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <!-- 基准测试按钮 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnBenchmark"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            app:cardCornerRadius="@dimen/radius_md"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/primary_light"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_lg"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="@dimen/icon_xl"
                                    android:layout_height="@dimen/icon_xl"
                                    android:src="@drawable/ic_benchmark"
                                    android:tint="@color/primary"
                                    android:contentDescription="基准测试" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="基准测试"
                                    android:textSize="@dimen/text_md"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold"
                                    android:layout_marginTop="@dimen/spacing_sm" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="性能评测"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="@dimen/spacing_xxs" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- 模型目录按钮 -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnModelCatalog"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            app:cardCornerRadius="@dimen/radius_md"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/success_light"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_lg"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="@dimen/icon_xl"
                                    android:layout_height="@dimen/icon_xl"
                                    android:src="@drawable/ic_models"
                                    android:tint="@color/success"
                                    android:contentDescription="模型目录" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="模型目录"
                                    android:textSize="@dimen/text_md"
                                    android:textColor="@color/success"
                                    android:textStyle="bold"
                                    android:layout_marginTop="@dimen/spacing_sm" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="下载管理"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="@dimen/spacing_xxs" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- 日志查看按钮 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnLogViewer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_lg"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:src="@drawable/ic_log"
                                android:tint="@color/text_secondary"
                                android:contentDescription="日志" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="日志查看"
                                    android:textSize="@dimen/text_md"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="查看运行日志和调试信息"
                                    android:textSize="@dimen/text_sm"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="@dimen/spacing_xxs" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_chevron_right"
                                android:tint="@color/text_tertiary"
                                android:contentDescription="进入" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 在线 API 配置入口 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnApiConfig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_variant"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_lg"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:src="@drawable/ic_cloud"
                                android:tint="@color/primary"
                                android:contentDescription="API" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="@dimen/spacing_md">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="在线 API 配置"
                                    android:textSize="@dimen/text_md"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/apiConfigStatusText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="点击配置免费 API 密钥"
                                    android:textSize="@dimen/text_sm"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="@dimen/spacing_xxs" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_chevron_right"
                                android:tint="@color/text_tertiary"
                                android:contentDescription="进入" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 版本信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="v1.0.0 • HiringAI ML Kit"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:layout_marginTop="@dimen/spacing_xl" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>