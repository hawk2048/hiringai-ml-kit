<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:background="@color/surface"
            android:elevation="@dimen/elevation_sm">

            <!-- 页面标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_models"
                    android:tint="@color/success"
                    android:contentDescription="模型" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Models"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginStart="@dimen/spacing_md" />
            </LinearLayout>

            <!-- 搜索栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 搜索输入框 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/searchInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/input_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:boxCornerRadiusTopStart="@dimen/radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                    app:boxBackgroundColor="@color/surface_variant"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/searchInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search models..."
                        android:inputType="text"
                        android:singleLine="true"
                        android:textSize="@dimen/text_md"
                        android:drawableStart="@drawable/ic_search"
                        android:drawablePadding="@dimen/spacing_sm" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 分类筛选（使用 ChipGroup 替代） -->
            </LinearLayout>
        </LinearLayout>

        <!-- 在线模型横幅 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/onlineModelsBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_cloud"
                    android:tint="@color/primary"
                    android:contentDescription="Online" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/onlineModelsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 online models"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to browse &amp; download"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/primary_variant" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Refresh"
                    android:textSize="@dimen/text_xs"
                    app:icon="@drawable/ic_refresh"
                    app:iconSize="16dp"
                    app:cornerRadius="@dimen/radius_full"
                    style="@style/Widget.Material3.Button.TonalButton" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 分类标签 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/surface"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:checked="true"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLlm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LLM"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEmbedding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Embedding"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Image"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSpeech"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speech"
                    style="@style/Widget.Material3.Chip.Filter" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- 加载指示 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 模型列表 -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/modelRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg" />

            </ScrollView>

            <!-- 空状态 -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_models"
                    android:tint="@color/text_tertiary"
                    android:alpha="0.5"
                    android:contentDescription="空" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No models found"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_md" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Try adjusting your search"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>

            <!-- 加载中 -->
            <LinearLayout
                android:id="@+id/loadingState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_md" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>