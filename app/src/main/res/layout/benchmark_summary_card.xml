<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="@dimen/elevation_lg"
    app:cardBackgroundColor="@color/card_background"
    style="@style/AppCardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/card_padding"
            android:background="@drawable/bg_gradient_header">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:src="@drawable/ic_benchmark"
                android:tint="@color/text_on_primary"
                android:contentDescription="Summary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Benchmark Summary"
                android:textSize="@dimen/text_lg"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/spacing_sm" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/totalModelsBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 Models"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/bg_badge_light"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_xs" />
        </LinearLayout>

        <!-- 统计网格 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding"
            android:baselineAligned="false">

            <!-- 最佳吞吐量 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_speed"
                    android:tint="@color/primary"
                    android:contentDescription="Best Throughput" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Throughput"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:id="@+id/bestThroughputValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/bestThroughputModel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- 最快加载 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_bolt"
                    android:tint="@color/success"
                    android:contentDescription="Fastest Load" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fastest Load"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:id="@+id/fastestLoadValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/success"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/fastestLoadModel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- 总耗时 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_timer"
                    android:tint="@color/info"
                    android:contentDescription="Total Time" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Time"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:id="@+id/totalTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/info"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="seconds"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- 设备信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/card_padding"
            android:paddingBottom="@dimen/card_padding">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_device"
                android:tint="@color/text_tertiary"
                android:contentDescription="Device" />

            <TextView
                android:id="@+id/deviceInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device info"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_tertiary"
                android:layout_marginStart="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
