<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- 页面标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xl">

                <ImageView
                    android:layout_width="@dimen/icon_lg"
                    android:layout_height="@dimen/icon_lg"
                    android:src="@drawable/ic_cloud"
                    android:tint="@color/primary"
                    android:contentDescription="API配置" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="在线 API 配置"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginStart="@dimen/spacing_md" />
            </LinearLayout>

            <!-- 说明卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_md"
                app:cardBackgroundColor="@color/warning_light"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="24dp"
                        android:layout_marginEnd="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="所有平台均需注册获取 API Key。推荐选择国内平台（无需科学上网）。\n\n本应用不收集您的密钥，仅本地存储。"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/warning" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 国内平台 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🇨🇳 国内平台（推荐，直连）"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- 硅基流动 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="硅基流动 SiliconFlow"
                            android:textSize="@dimen/text_md"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSiliconflow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未配置"
                            android:textSize="@dimen/text_xs"
                            app:chipBackgroundColor="@color/surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="永久免费 | 支持 Qwen/DeepSeek/Llama 等 | 直连"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/success"
                        android:layout_marginTop="@dimen/spacing_xs" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="API Key"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editSiliconflowKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="@dimen/text_sm" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveSiliconflow"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="保存"
                        android:textSize="@dimen/text_sm"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 智谱 AI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="智谱 AI BigModel"
                            android:textSize="@dimen/text_md"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipZhipu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未配置"
                            android:textSize="@dimen/text_xs"
                            app:chipBackgroundColor="@color/surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="无 Token 上限（限并发）| GLM-4-Flash | 直连"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/success"
                        android:layout_marginTop="@dimen/spacing_xs" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="API Key"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editZhipuKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="@dimen/text_sm" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveZhipu"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="保存"
                        android:textSize="@dimen/text_sm"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 阿里云百炼 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="阿里云百炼"
                            android:textSize="@dimen/text_md"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAliyun"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未配置"
                            android:textSize="@dimen/text_xs"
                            app:chipBackgroundColor="@color/surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="新用户 7000万 Tokens | Qwen 系列 | 直连"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/success"
                        android:layout_marginTop="@dimen/spacing_xs" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="API Key"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editAliyunKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="@dimen/text_sm" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveAliyun"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="保存"
                        android:textSize="@dimen/text_sm"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 国际平台 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐 国际平台（需要科学上网）"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_md" />

            <!-- Groq -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Groq API"
                            android:textSize="@dimen/text_md"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipGroq"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未配置"
                            android:textSize="@dimen/text_xs"
                            app:chipBackgroundColor="@color/surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="每天 14,400 次请求 | Llama/DeepSeek 等 | 超快速度"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/warning"
                        android:layout_marginTop="@dimen/spacing_xs" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="API Key"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editGroqKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="@dimen/text_sm" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveGroq"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="保存"
                        android:textSize="@dimen/text_sm"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- OpenRouter -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/card_background"
                style="@style/AppCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="OpenRouter"
                            android:textSize="@dimen/text_md"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOpenrouter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未配置"
                            android:textSize="@dimen/text_xs"
                            app:chipBackgroundColor="@color/surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="每天 50 次免费 | DeepSeek/Llama 等 100+ 模型"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/warning"
                        android:layout_marginTop="@dimen/spacing_xs" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:hint="API Key"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editOpenrouterKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="@dimen/text_sm" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveOpenrouter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="保存"
                        android:textSize="@dimen/text_sm"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
