<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="@dimen/elevation_md"
    app:cardBackgroundColor="@color/card_background"
    style="@style/AppCardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部状态栏：模型名 + 状态标签 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/card_padding"
            android:background="@color/surface_variant">

            <!-- 左侧分类色条 -->
            <View
                android:id="@+id/categoryIndicator"
                android:layout_width="@dimen/color_bar_width"
                android:layout_height="40dp"
                android:background="@color/primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_md">

                <TextView
                    android:id="@+id/modelName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model Name"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/modelSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="378 MB"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_xxs" />
            </LinearLayout>

            <!-- 状态标签 -->
            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Success"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/bg_badge_success"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_xs" />
        </LinearLayout>

        <!-- 核心指标区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding"
            android:baselineAligned="false">

            <!-- 吞吐量卡片 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Throughput"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/throughputValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12.5"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="tokens/s"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- 加载时间卡片 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Load Time"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/loadTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.3s"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/info"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ms"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- Token 数量卡片 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tokens"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tokensValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/success"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="generated"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- 内存使用进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/card_padding"
            android:paddingBottom="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_xs">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Memory"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/memoryValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="256 MB"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/memoryProgressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:indicatorColor="@color/accent"
                app:trackColor="@color/surface_variant"
                app:trackCornerRadius="@dimen/radius_sm"
                app:trackThickness="6dp"
                android:max="100"
                android:progress="30" />
        </LinearLayout>

        <!-- 错误信息（失败时显示） -->
        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_padding"
            android:text="Error message here"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/error"
            android:visibility="gone"
            android:drawableStart="@drawable/ic_error"
            android:drawablePadding="@dimen/spacing_sm" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
